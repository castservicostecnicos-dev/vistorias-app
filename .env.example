# .env.example — example environment variables for local development
# Copy this to .env.local and fill the values (DO NOT commit actual secret keys in a public repo).

# Public (client) values — safe for the browser
NEXT_PUBLIC_SUPABASE_URL=https://<YOUR_PROJECT>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<ANON_PUBLIC_KEY>

# Server values — DO NOT expose these to the client or commit to public repos
SUPABASE_URL=https://<YOUR_PROJECT>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<SERVICE_ROLE_KEY>

# Optional audit DB (if used)
# AUDIT_SUPABASE_URL=
# AUDIT_SUPABASE_SERVICE_ROLE_KEY=

# Test user credentials (use only for local testing)
EMAIL=teste+dev@seu-dominio.com
PASSWORD=TempPass123!

# Notes:
# - NEXT_PUBLIC_* variables are embedded into client builds, so only use the anon/public key there.
# - SUPABASE_SERVICE_ROLE_KEY is powerful and must only be used server-side (Next.js API routes),
#   never put it in the browser or in a public repository.
# - To start locally:
#     1) Copy this file to .env.local:  cp .env.example .env.local  (or use an editor)
#     2) Fill the values from your Supabase project Settings → API
#     3) npm install && npm run dev
# - To get an access token for testing (PowerShell):
#     $env:SUPABASE_URL = 'https://<YOUR_PROJECT>.supabase.co'
#     $env:ANON_KEY = '<ANON_PUBLIC_KEY>'
#     $env:EMAIL = 'teste+dev@seu-dominio.com'
#     $env:PASSWORD = 'TempPass123!'
#     node ./get_token.js
